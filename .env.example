# Frontend env (Vite). Copy to .env.local for local overrides. Vite only exposes
# variables prefixed with VITE_ to the client.

# Base URL of the Pandemonium backend API. Defaults to the local dev server if
# unset (see src/data/session.js). In production set this to the deployed API,
# e.g. https://api.pandemonium.app/v1
VITE_API_BASE=http://localhost:8787/v1
