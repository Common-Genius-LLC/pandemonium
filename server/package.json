{
  "name": "pandemonium-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pandemonium backend: accounts and remote project persistence (Phase A document sync). Bun + Hono + Postgres, TypeScript.",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "migrate": "bun src/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.12.31"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
