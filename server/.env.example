# Copy to .env and edit. Bun auto-loads .env; never commit the real file.
PORT=8787

# HS256 signing secret for access tokens. Use at least 32 random bytes in prod.
JWT_SECRET=dev-insecure-change-me-0123456789abcdef

# Where the Vite dev server runs, echoed back as the CORS origin (credentials
# are included for the refresh cookie, so this cannot be "*").
CORS_ORIGIN=http://localhost:5173

# PostgreSQL connection string. `docker compose up -d db` starts one matching
# these defaults. In prod point this at the OCI Postgres per
# docs/BACKEND_ARCHITECTURE.md.
DATABASE_URL=postgres://pandemonium:devpassword@localhost:5432/pandemonium

# Set true when serving over HTTPS across sites (Cloudflare Pages -> OCI). It
# switches the refresh cookie to Secure + SameSite=None. Leave false for local
# http dev.
COOKIE_SECURE=false
