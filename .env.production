# Frontend env for production builds (`bun run build`). Vite loads this in
# production mode and inlines VITE_* values into the bundle. This is a public
# value (the API base URL), safe to commit.
#
# The backend API. It must end in /v1 (all routes live under it). Change this if
# the backend lands on a different host, then rebuild and redeploy.
VITE_API_BASE=https://api.pandemonium.commongenius.in/v1
